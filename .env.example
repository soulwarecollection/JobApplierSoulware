# Copy to .env and fill in. Only ANTHROPIC_API_KEY is needed for scoring.
# Without it, run with --no-llm to just aggregate + track (no AI ranking).

ANTHROPIC_API_KEY=

# Optional: override the scoring model. Default is claude-opus-4-8 (best quality).
# Cheaper options for high-volume scoring (your cost/quality call):
#   claude-sonnet-4-6   (mid)
#   claude-haiku-4-5    (cheapest)
ANTHROPIC_MODEL=claude-opus-4-8

# Optional aggregator key (free tier) — adds Adzuna as a source.
# Get one at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
